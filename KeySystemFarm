if getgenv().KEY_farm then return end
getgenv().KE_Yfarm= true    
--────────────────────────────────────────
local Players      = game:GetService("Players")
local HttpService  = game:GetService("HttpService")
local CoreGui      = game:GetService("CoreGui")
local LocalPlayer  = Players.LocalPlayer

-- ── Configuración ────────────────────────────────────
local REPO         = "https://raw.githubusercontent.com/deividcomsono/Obsidian/main/"
local BASE = "https://hub-sb-v-default-rtdb.firebaseio.com/keys/"
local HUB_URL      = "https://raw.githubusercontent.com/King-Scripts/JL-Script-s/refs/heads/main/Farm"  -- ← CAMBIA A TU HUB REAL

local HWID         = tostring(LocalPlayer.UserId)
local KeyVerified  = false
local LastAttempt  = 0
local COOLDOWN     = 1.2  -- segundos entre intentos

-- ── Cargar Library ───────────────────────────────────
local Library
do
    local success, result = pcall(loadstring, game:HttpGet(REPO .. "Library.lua", true))
    if not success or not result then
        warn("[KeySystem] No se pudo cargar la UI")
        return
    end
    Library = result()
end

-- ── Ventana discreta solo para key ───────────────────
local KeyWindow = Library:CreateWindow({
    Title       = "Verificación",
    Footer      = "By JX",
    Center      = true,
    AutoShow    = true,
    Resizable   = true,
    ShowCustomCursor = false,
    Size        = UDim2.fromOffset(340, 190)
})
Window:SetCornerRadius(15)

local Tab = KeyWindow:AddTab("KeyHub", "lock")   -- Tab sin nombre visible
local Group = Tab:AddLeftGroupbox("Verificar Key")

-- ── Función de notificación más limpia ───────────────
local function Notify(title, desc, duration)
    Library:Notify({Title = title, Description = desc, Duration = duration or 3.2})
end

-- ── Verificador de key optimizado ────────────────────
local function VerifyKey(input)
    input = input:match("^%s*(.-)%s*$") or ""
    if input == "" then return false end

    local url = BASE .. input .. ".json"

    local success, response = pcall(game.HttpGet, game, url, true)
    if not success or not response or response == "null" then
        Notify("Key", "Key inválida", 3.5)
        return false
    end

    local data = HttpService:JSONDecode(response)

    local expire = tonumber(data.expire or 0)
    local storedHWID = tostring(data.hwid or "0")

    -- Expiración
    if expire > 0 and expire < os.time() then
        Notify("Key", "La key ha expirado", 4.5)
        return false
    end

    -- HWID
    if storedHWID ~= "0" and storedHWID ~= HWID then
        Notify("Key", "Key usada en otro usuario", 5)
        return false
    end

    return true
end

-- ── UI Elements ──────────────────────────────────────
local keyInput = ""
Group:AddInput("KeyInput", {
    Text = "",
    Placeholder = "Ingresa tu key aquí...",
    Default = "",
    ClearTextOnFocus = true,
    Callback = function(value)
        keyInput = value
    end,
})

Group:AddDivider()

Group:AddButton({
    Text = "Verificar Key",
    Func = function()
        local now = tick()
        if now - LastAttempt < COOLDOWN then
            Notify("Espera", "Espera un momento antes de intentar de nuevo", 2.5)
            return
        end
        LastAttempt = now

        if VerifyKey(keyInput) then
            KeyVerified = true
            Notify("Éxito", "Acceso concedido", 2.5)

            -- Carga asíncrona + limpieza
            task.defer(function()
                task.wait(0.35)

                -- Destruir ventana de key inmediatamente
                pcall(function() KeyWindow:Destroy() end)

                task.wait(0.25)

                -- Cargar hub principal
                local hubSuccess, hubErr = pcall(function()
                    loadstring(game:HttpGet(HUB_URL, true))()
                end)

                if not hubSuccess then
                    warn("[KeySystem] Error al cargar hub: " .. tostring(hubErr))
                    Notify("Error", "No se pudo cargar el hub principal", 6)
                end

                -- Limpieza agresiva pero segura (después de cargar)
                task.delay(0.3, function()
                    -- 1. Destruir ScreenGui de la library (muy común en Obsidian/Linoria)
                    pcall(function()
                        if Library and Library.ScreenGui then
                            Library.ScreenGui:Destroy()
                        end
                    end)

                    -- 2. Buscar y destruir cualquier ScreenGui sospechosa
                    for _, obj in CoreGui:GetChildren() do
                        if obj:IsA("ScreenGui") and (
                            obj.Name:lower():find("key") or
                            obj.Name:lower():find("verif") or
                            obj.Name:lower():find("obsidian") or
                            obj.Name:lower():find("hub") or
                            obj.Name == "KeySystem"
                        ) then
                            pcall(obj.Destroy, obj)
                        end
                    end

                    -- 3. Limpiar algunas variables globales comunes
                    for k in pairs(_G) do
                        if type(_G[k]) == "function" and debug.info and debug.info(_G[k], "s"):find("KeySystem", 1, true) then
                            _G[k] = nil
                        end
                    end

                    -- 4. Intentar renombrar script (muy limitado pero puede ayudar en algunos casos)
                    pcall(function() script.Name = tostring(math.random(10000,999999)) end)
                end)
            end)
        end
    end
})

Group:AddButton({
    Text = "Obtener Key",
    Func = function()
        if setclipboard then
            setclipboard("https://discord.com/users/1419243607097081918")  -- o tu link real
            Notify("Copiado", "Enlace al proveedor de keys copiado", 2.8)
        else
            Notify("Error", "No se puede copiar (setclipboard no disponible)", 4)
        end
    end
})

-- ── Protección mínima contra bypass simple ───────────
getgenv().IsKeyVerified = function() return KeyVerified end
